#5- Reverse Array Elements( Or use Void )

#include<iostream>
#include<vector>
using namespace std;
vector<int> reverse(vector<int>&nums){
    vector<int>ans;
    int n=nums.size();
    for(int i=n-1;i>=0;i--)
    ans.push_back(nums[i]);
    return ans;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    cin>>nums[i];
    vector<int>ans=reverse(nums);
    for(int i=0;i<ans.size();i++)
    cout<<ans[i];
}
