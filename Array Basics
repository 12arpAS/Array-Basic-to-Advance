#7- Frequency of Array Elements

#include<iostream>
#include<vector>
using namespace std;
int frequency(vector<int>&nums,int key){
    int n=nums.size();
    int freq=0;
    for(int i=0;i<n;i++){
        if(nums[i]==key)
        freq++;
    }
    return freq;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    cin>>nums[i];
    int key;
    cin>>key;
    cout<<frequency(nums,key);
}
