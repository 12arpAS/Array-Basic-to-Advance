#10- Max and Min element combinly

#include<iostream>
#include<vector>
using namespace std;
vector<int>maxmin(vector<int>&nums){
    vector<int>ans;
    int n=nums.size();
    int max=nums[0];
    int min=nums[0];
    for(int i=0;i<n;i++){
        if(nums[i]>max)
        max=nums[i];
        
        if(nums[i]<min)
        min=nums[i];
    }
    ans.push_back(max);
    ans.push_back(min);
    return ans;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    cin>>nums[i];
    vector<int>result=maxmin(nums);
    for(int i=0;i<result.size();i++)
    cout<<result[i]<<" ";
}

