#2- Count Even and Odd ELements of Array
--------------------------------------------------------
#include<iostream>
#include<vector>
using namespace std;
void countarr(vector<int>&nums){
    int n=nums.size();
    int odd=0;
    int even=0;
    for(int i=0;i<n;i++){
        if(nums[i]%2==0)
        even++;
        else
        odd++;
    }
    cout<<even;
    cout<<odd;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    cin>>nums[i];
    countarr(nums);
}
