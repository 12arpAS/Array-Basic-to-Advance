#3- Sum of Even and Product of Odd elements of Array

#include<iostream>
#include<vector>
using namespace std;
void sumprod(vector<int>&nums){
    int n=nums.size();
    int sum=0;
    int prod=1;
    for(int i=0;i<n;i++){
        if(nums[i]%2==0)
        sum=sum+nums[i];
        else
        prod=prod*nums[i];
    }
    cout<<sum<<" "<<prod;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    cin>>nums[i];
    sumprod(nums);
}
