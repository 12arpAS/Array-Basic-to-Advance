#6- Linear Search 

#include<iostream>
#include<vector>
using namespace std;
bool linearsearch(vector<int>&nums,int key){
    int n=nums.size();
    for(int i=0;i<n;i++){
        if(nums[i]==key)
        return true;
    }
    return false;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++)
    cin>>nums[i];
    int key;
    cin>>key;
    cout<<linearsearch(nums,key);
}
