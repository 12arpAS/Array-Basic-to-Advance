#8- Maximum ELements of Array

#include<iostream>
#include<vector>
using namespace std;
int maxelement(vector<int>&nums){
    int n=nums.size();
    int max=nums[0];
    for(int i=0;i<nums.size();i++){
        if(nums[i]>max)
        max=nums[i];
    }
    return max;
}
int main(){
    int n;
    cin>>n;
    vector<int>nums(n);
    for(int i=0;i<n;i++ )
    cin>>nums[i];
    cout<<maxelement(nums);
}
